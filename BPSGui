local UIS = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

local Library = {}

if CoreGui:FindFirstChild("CustomLibrary") then
    CoreGui:FindFirstChild("CustomLibrary"):Destroy()
end

function Library:CreateWindow(title)
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "CustomLibrary"
    ScreenGui.Parent = CoreGui
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.ResetOnSpawn = false

    local Main = Instance.new("Frame")
    Main.Name = "Main"
    Main.Parent = ScreenGui
    Main.BackgroundColor3 = Color3.fromRGB(12, 12, 14)
    Main.Position = UDim2.new(0.5, -275, 0.5, -150)
    Main.Size = UDim2.new(0, 550, 0, 300)
    Main.BorderSizePixel = 0
    Main.ClipsDescendants = true

    local MainStroke = Instance.new("UIStroke")
    MainStroke.Thickness = 1
    MainStroke.Color = Color3.fromRGB(45, 45, 45)
    MainStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    MainStroke.Parent = Main

    local TopBar = Instance.new("Frame")
    TopBar.Name = "TopBar"
    TopBar.Parent = Main
    TopBar.BackgroundColor3 = Color3.fromRGB(5, 5, 5)
    TopBar.Size = UDim2.new(1, 0, 0, 25)
    TopBar.BorderSizePixel = 0

    local Title = Instance.new("TextLabel")
    Title.Parent = TopBar
    Title.BackgroundTransparency = 1
    Title.Position = UDim2.new(0, 10, 0, 0)
    Title.Size = UDim2.new(1, -70, 1, 0)
    Title.Font = Enum.Font.Code
    Title.Text = title or "UI Library"
    Title.TextColor3 = Color3.fromRGB(220, 220, 220)
    Title.TextSize = 13
    Title.TextXAlignment = Enum.TextXAlignment.Left

    local Controls = Instance.new("Frame")
    Controls.Name = "Controls"
    Controls.Parent = TopBar
    Controls.BackgroundTransparency = 1
    Controls.Position = UDim2.new(1, -55, 0, 0)
    Controls.Size = UDim2.new(0, 50, 1, 0)
    Controls.Visible = false

    local function CreateControlBtn(txt)
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(0, 20, 1, 0)
        b.BackgroundTransparency = 1
        b.Font = Enum.Font.Code
        b.Text = txt
        b.TextColor3 = Color3.fromRGB(255, 255, 255)
        b.TextSize = 14
        b.Parent = Controls
        return b
    end

    local minBtn = CreateControlBtn("^")
    local maxBtn = CreateControlBtn("□")

    local RainbowLine = Instance.new("Frame")
    RainbowLine.Parent = TopBar
    RainbowLine.BorderSizePixel = 0
    RainbowLine.Position = UDim2.new(0, 0, 1, 0)
    RainbowLine.Size = UDim2.new(1, 0, 0, 1)

    RunService.RenderStepped:Connect(function()
        RainbowLine.BackgroundColor3 = Color3.fromHSV(tick() % 5 / 5, 1, 1)
    end)

    local TabContainer = Instance.new("ScrollingFrame")
    TabContainer.Name = "TabContainer"
    TabContainer.Parent = Main
    TabContainer.BackgroundTransparency = 1
    TabContainer.Position = UDim2.new(0, 5, 1, -25)
    TabContainer.Size = UDim2.new(1, -10, 0, 22)
    TabContainer.CanvasSize = UDim2.new(0, 0, 0, 0)
    TabContainer.ScrollBarThickness = 0
    TabContainer.ScrollingDirection = Enum.ScrollingDirection.X

    local TabList = Instance.new("UIListLayout")
    TabList.Parent = TabContainer
    TabList.FillDirection = Enum.FillDirection.Horizontal
    TabList.SortOrder = Enum.SortOrder.LayoutOrder
    TabList.Padding = UDim.new(0, 12)

    local PageFolder = Instance.new("Folder")
    PageFolder.Name = "Pages"
    PageFolder.Parent = Main

    local lastClick = 0
    TopBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local currentTime = tick()
            if currentTime - lastClick < 0.3 then
                Controls.Visible = not Controls.Visible
            end
            lastClick = currentTime
        end
    end)

    minBtn.MouseButton1Click:Connect(function()
        TabContainer.Visible = false
        PageFolder.Parent = nil
        TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(0, 550, 0, 26)}):Play()
    end)

    maxBtn.MouseButton1Click:Connect(function()
        PageFolder.Parent = Main
        TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(0, 550, 0, 300)}):Play()
        task.delay(0.3, function() TabContainer.Visible = true end)
    end)

    local dragging, dragStart, startPos
    TopBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = Main.Position
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    local Tabs = {}
    local firstPage = true

    function Tabs:CreateTab(name)
        local Page = Instance.new("ScrollingFrame")
        Page.Name = name .. "Page"
        Page.Parent = PageFolder
        Page.BackgroundTransparency = 1
        Page.Position = UDim2.new(0, 10, 0, 40)
        Page.Size = UDim2.new(1, -20, 1, -85)
        Page.Visible = firstPage
        Page.ScrollBarThickness = 0
        Page.CanvasSize = UDim2.new(0, 0, 0, 0)
        Page.ClipsDescendants = false

        local PageGrid = Instance.new("UIGridLayout")
        PageGrid.Parent = Page
        PageGrid.SortOrder = Enum.SortOrder.LayoutOrder
        PageGrid.CellPadding = UDim2.new(0, 10, 0, 10)
        PageGrid.CellSize = UDim2.new(0, 160, 0, 30)

        local TabButton = Instance.new("TextButton")
        TabButton.Parent = TabContainer
        TabButton.BackgroundTransparency = 1
        TabButton.Font = Enum.Font.Code
        TabButton.Text = name
        TabButton.TextColor3 = firstPage and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(120, 120, 120)
        TabButton.TextSize = 15
        TabButton.AutomaticSize = Enum.AutomaticSize.X

        TabButton.MouseButton1Click:Connect(function()
            for _, v in pairs(PageFolder:GetChildren()) do v.Visible = false end
            for _, v in pairs(TabContainer:GetChildren()) do 
                if v:IsA("TextButton") then v.TextColor3 = Color3.fromRGB(120, 120, 120) end 
            end
            Page.Visible = true
            TabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        end)

        firstPage = false
        TabContainer.CanvasSize = UDim2.new(0, TabList.AbsoluteContentSize.X, 0, 0)

        local Elements = {}

        local function AddStroke(parent)
            local Stroke = Instance.new("UIStroke")
            Stroke.Thickness = 1
            Stroke.Color = Color3.fromRGB(45, 45, 45)
            Stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            Stroke.Parent = parent
            return Stroke
        end

        function Elements:CreateButton(text, callback)
            local Button = Instance.new("TextButton")
            Button.Parent = Page
            Button.BackgroundColor3 = Color3.fromRGB(18, 18, 20)
            Button.BorderSizePixel = 0
            Button.Font = Enum.Font.Code
            Button.Text = text
            Button.TextColor3 = Color3.fromRGB(200, 200, 200)
            Button.TextSize = 13
            AddStroke(Button)
            Button.MouseButton1Click:Connect(callback)
            Page.CanvasSize = UDim2.new(0, 0, 0, PageGrid.AbsoluteContentSize.Y)
        end

        function Elements:CreateToggle(text, default, callback)
            local state = default
            local Toggle = Instance.new("TextButton")
            Toggle.Parent = Page
            Toggle.BackgroundColor3 = Color3.fromRGB(18, 18, 20)
            Toggle.BorderSizePixel = 0
            Toggle.Font = Enum.Font.Code
            Toggle.Text = text
            Toggle.TextColor3 = Color3.fromRGB(200, 200, 200)
            Toggle.TextSize = 13
            AddStroke(Toggle)

            local Indicator = Instance.new("Frame")
            Indicator.Size = UDim2.new(1, 0, 0, 1)
            Indicator.Position = UDim2.new(0, 0, 1, -1)
            Indicator.BorderSizePixel = 0
            Indicator.BackgroundColor3 = state and Color3.fromRGB(0, 255, 120) or Color3.fromRGB(255, 60, 60)
            Indicator.Parent = Toggle

            Toggle.MouseButton1Click:Connect(function()
                state = not state
                Indicator.BackgroundColor3 = state and Color3.fromRGB(0, 255, 120) or Color3.fromRGB(255, 60, 60)
                callback(state)
            end)
            Page.CanvasSize = UDim2.new(0, 0, 0, PageGrid.AbsoluteContentSize.Y)
        end

        function Elements:CreateTextBox(placeholder, callback)
            local Box = Instance.new("TextBox")
            Box.Parent = Page
            Box.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
            Box.BorderSizePixel = 0
            Box.Font = Enum.Font.Code
            Box.PlaceholderText = placeholder
            Box.Text = ""
            Box.TextColor3 = Color3.fromRGB(255, 255, 255)
            Box.TextSize = 13
            Box.ClearTextOnFocus = false
            AddStroke(Box)

            Box.FocusLost:Connect(function(enterPressed)
                local input = Box.Text
                Box.Text = ""
                callback(input)
            end)
            Page.CanvasSize = UDim2.new(0, 0, 0, PageGrid.AbsoluteContentSize.Y)
        end

        function Elements:CreateDropdown(name, options, callback)
            local Dropdown = Instance.new("TextButton")
            Dropdown.Parent = Page
            Dropdown.BackgroundColor3 = Color3.fromRGB(18, 18, 20)
            Dropdown.BorderSizePixel = 0
            Dropdown.Font = Enum.Font.Code
            Dropdown.Text = name
            Dropdown.TextColor3 = Color3.fromRGB(200, 200, 200)
            Dropdown.TextSize = 13
            AddStroke(Dropdown)

            local Container = Instance.new("ScrollingFrame")
            Container.Parent = Dropdown
            Container.BackgroundColor3 = Color3.fromRGB(12, 12, 14)
            Container.BorderSizePixel = 0
            Container.Position = UDim2.new(0, 0, 1, 1)
            Container.Size = UDim2.new(1, 0, 0, 100)
            Container.Visible = false
            Container.ZIndex = 50
            Container.ScrollBarThickness = 2
            Container.ScrollBarImageColor3 = Color3.fromRGB(45, 45, 45)
            AddStroke(Container)

            local UIList = Instance.new("UIListLayout")
            UIList.Parent = Container
            UIList.SortOrder = Enum.SortOrder.LayoutOrder

            local open = false
            Dropdown.MouseButton1Click:Connect(function()
                open = not open
                Container.Visible = open
            end)

            for _, option in pairs(options) do
                local OptBtn = Instance.new("TextButton")
                OptBtn.Size = UDim2.new(1, 0, 0, 25)
                OptBtn.BackgroundColor3 = Color3.fromRGB(18, 18, 20)
                OptBtn.BorderSizePixel = 0
                OptBtn.Font = Enum.Font.Code
                OptBtn.Text = option
                OptBtn.TextColor3 = Color3.fromRGB(120, 120, 120)
                OptBtn.TextSize = 12
                OptBtn.Parent = Container
                OptBtn.ZIndex = 51

                OptBtn.MouseButton1Click:Connect(function()
                    for _, v in pairs(Container:GetChildren()) do
                        if v:IsA("TextButton") then
                            v.TextColor3 = (v.Text == option) and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(120, 120, 120)
                        end
                    end
                    open = false
                    Container.Visible = false
                    callback(option)
                end)
            end
            Container.CanvasSize = UDim2.new(0, 0, 0, #options * 25)
            Page.CanvasSize = UDim2.new(0, 0, 0, PageGrid.AbsoluteContentSize.Y)
        end

        function Elements:CreateBind(name, defaultBind, callback)
            local currentBind = defaultBind
            
            local BindFrame = Instance.new("Frame")
            BindFrame.Parent = Page
            BindFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            BindFrame.BorderSizePixel = 0
            AddStroke(BindFrame)

            local BindBox = Instance.new("TextBox")
            BindBox.Parent = BindFrame
            BindBox.Size = UDim2.new(1, 0, 0, 22)
            BindBox.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            BindBox.BorderSizePixel = 0
            BindBox.Font = Enum.Font.Code
            BindBox.PlaceholderText = "[" .. tostring(currentBind.Name) .. "]"
            BindBox.Text = ""
            BindBox.TextColor3 = Color3.fromRGB(255, 255, 255)
            BindBox.TextSize = 11
            AddStroke(BindBox)

            local BindLabel = Instance.new("TextLabel")
            BindLabel.Parent = BindFrame
            BindLabel.Size = UDim2.new(1, 0, 0, 32)
            BindLabel.Position = UDim2.new(0, 0, 0, 22)
            BindLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            BindLabel.BorderSizePixel = 0
            BindLabel.Font = Enum.Font.Code
            BindLabel.Text = name
            BindLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            BindLabel.TextSize = 12
            AddStroke(BindLabel)

            BindBox.FocusLost:Connect(function(enterPressed)
                if enterPressed then
                    local newKey = BindBox.Text:upper()
                    pcall(function()
                        currentBind = Enum.KeyCode[newKey]
                        BindBox.PlaceholderText = "[" .. newKey .. "]"
                    end)
                    BindBox.Text = ""
                end
            end)

            UIS.InputBegan:Connect(function(input, gpe)
                if not gpe and input.KeyCode == currentBind then
                    callback()
                end
            end)
            
            Page.CanvasSize = UDim2.new(0, 0, 0, PageGrid.AbsoluteContentSize.Y)
        end

        return Elements
    end
    return Tabs
end

return Library
