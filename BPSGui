local UIS = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

local Library = {}

if CoreGui:FindFirstChild("CustomLibrary") then
    CoreGui:FindFirstChild("CustomLibrary"):Destroy()
end

function Library:CreateWindow(title)
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "CustomLibrary"
    ScreenGui.Parent = CoreGui
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.ResetOnSpawn = false

    local Main = Instance.new("Frame")
    Main.Name = "Main"
    Main.Parent = ScreenGui
    Main.BackgroundColor3 = Color3.fromRGB(15, 15, 17)
    Main.Position = UDim2.new(0.5, -275, 0.5, -150)
    Main.Size = UDim2.new(0, 550, 0, 300)
    Main.BorderSizePixel = 0
    Main.ClipsDescendants = true

    local MainCorner = Instance.new("UICorner")
    MainCorner.CornerRadius = UDim.new(0, 6)
    MainCorner.Parent = Main

    local MainStroke = Instance.new("UIStroke")
    MainStroke.Thickness = 1.2
    MainStroke.Color = Color3.fromRGB(45, 45, 50)
    MainStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    MainStroke.Parent = Main

    local TopBar = Instance.new("Frame")
    TopBar.Name = "TopBar"
    TopBar.Parent = Main
    TopBar.BackgroundColor3 = Color3.fromRGB(10, 10, 12)
    TopBar.Size = UDim2.new(1, 0, 0, 30)
    TopBar.BorderSizePixel = 0

    local TopCorner = Instance.new("UICorner")
    TopCorner.CornerRadius = UDim.new(0, 6)
    TopCorner.Parent = TopBar

    local Title = Instance.new("TextLabel")
    Title.Parent = TopBar
    Title.BackgroundTransparency = 1
    Title.Position = UDim2.new(0, 12, 0, 0)
    Title.Size = UDim2.new(1, -80, 1, 0)
    Title.Font = Enum.Font.Code
    Title.Text = title or "UI Library"
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.TextSize = 14
    Title.TextXAlignment = Enum.TextXAlignment.Left

    local RainbowLine = Instance.new("Frame")
    RainbowLine.Name = "RainbowLine"
    RainbowLine.Parent = TopBar
    RainbowLine.BorderSizePixel = 0
    RainbowLine.Position = UDim2.new(0, 0, 1, -1)
    RainbowLine.Size = UDim2.new(1, 0, 0, 1)

    RunService.RenderStepped:Connect(function()
        RainbowLine.BackgroundColor3 = Color3.fromHSV(tick() % 5 / 5, 0.8, 1)
    end)

    local currentTypewrite = 0
    local function Typewrite(text)
        currentTypewrite = currentTypewrite + 1
        local thisId = currentTypewrite
        Title.Text = ""
        for i = 1, #text do
            if thisId ~= currentTypewrite then return end
            Title.Text = string.sub(text, 1, i)
            task.wait(0.01)
        end
    end

    local function ResetTitle()
        Typewrite(title or "UI Library")
    end

    local TabContainer = Instance.new("ScrollingFrame")
    TabContainer.Name = "TabContainer"
    TabContainer.Parent = Main
    TabContainer.BackgroundTransparency = 1
    TabContainer.Position = UDim2.new(0, 10, 1, -30)
    TabContainer.Size = UDim2.new(1, -20, 0, 25)
    TabContainer.CanvasSize = UDim2.new(0, 0, 0, 0)
    TabContainer.ScrollBarThickness = 0
    TabContainer.ScrollingDirection = Enum.ScrollingDirection.X

    local TabList = Instance.new("UIListLayout")
    TabList.Parent = TabContainer
    TabList.FillDirection = Enum.FillDirection.Horizontal
    TabList.SortOrder = Enum.SortOrder.LayoutOrder
    TabList.VerticalAlignment = Enum.VerticalAlignment.Center
    TabList.Padding = UDim.new(0, 15)

    local PageFolder = Instance.new("Folder")
    PageFolder.Name = "Pages"
    PageFolder.Parent = Main

    local dragging, dragStart, startPos
    TopBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = Main.Position
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    local Tabs = {}
    local firstPage = true

    function Tabs:AddTab(name)
        local Page = Instance.new("ScrollingFrame")
        Page.Name = name .. "Page"
        Page.Parent = PageFolder
        Page.BackgroundColor3 = Color3.fromRGB(15, 15, 17)
        Page.BackgroundTransparency = 0.2
        Page.Position = UDim2.new(0, 15, 0, 45)
        Page.Size = UDim2.new(1, -30, 1, -85)
        Page.Visible = firstPage
        Page.ScrollBarThickness = 2
        Page.ScrollBarImageColor3 = Color3.fromRGB(45, 45, 45)
        Page.BorderSizePixel = 0

        local PageCorner = Instance.new("UICorner")
        PageCorner.CornerRadius = UDim.new(0, 6)
        PageCorner.Parent = Page

        local PageGrid = Instance.new("UIGridLayout")
        PageGrid.Parent = Page
        PageGrid.SortOrder = Enum.SortOrder.LayoutOrder
        PageGrid.CellPadding = UDim2.new(0, 8, 0, 8)
        PageGrid.CellSize = UDim2.new(0, 124, 0, 32)

        local TabButton = Instance.new("TextButton")
        TabButton.Parent = TabContainer
        TabButton.BackgroundTransparency = 1
        TabButton.Font = Enum.Font.Code
        TabButton.Text = name:upper()
        TabButton.TextColor3 = firstPage and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(100, 100, 100)
        TabButton.TextSize = 13
        TabButton.Size = UDim2.new(0, 40, 1, 0)
        TabButton.AutomaticSize = Enum.AutomaticSize.X

        TabButton.MouseButton1Click:Connect(function()
            for _, v in pairs(PageFolder:GetChildren()) do v.Visible = false end
            for _, v in pairs(TabContainer:GetChildren()) do 
                if v:IsA("TextButton") then 
                    TweenService:Create(v, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(100, 100, 100)}):Play()
                end 
            end
            Page.Visible = true
            TweenService:Create(TabButton, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
        end)

        firstPage = false
        TabContainer.CanvasSize = UDim2.new(0, TabList.AbsoluteContentSize.X, 0, 0)

        local Elements = {}

        local function StyleElement(obj)
            local stroke = Instance.new("UIStroke")
            stroke.Thickness = 1
            stroke.Color = Color3.fromRGB(40, 40, 45)
            stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            stroke.Parent = obj

            obj.MouseEnter:Connect(function()
                TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(80, 80, 90)}):Play()
            end)
            obj.MouseLeave:Connect(function()
                TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(40, 40, 45)}):Play()
            end)
        end

        function Elements:AddButton(text, desc, callback)
            local Button = Instance.new("TextButton")
            Button.Parent = Page
            Button.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
            Button.Font = Enum.Font.Code
            Button.Text = text
            Button.TextColor3 = Color3.fromRGB(200, 200, 200)
            Button.TextSize = 12
            StyleElement(Button)

            Button.MouseEnter:Connect(function() Typewrite(desc or text) end)
            Button.MouseLeave:Connect(ResetTitle)
            Button.MouseButton1Click:Connect(callback)
            
            RunService.Heartbeat:Wait()
            Page.CanvasSize = UDim2.new(0, 0, 0, PageGrid.AbsoluteContentSize.Y)
        end

        function Elements:AddToggle(text, desc, default, callback)
            local state = default
            local Toggle = Instance.new("TextButton")
            Toggle.Parent = Page
            Toggle.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
            Toggle.Font = Enum.Font.Code
            Toggle.Text = text
            Toggle.TextColor3 = Color3.fromRGB(200, 200, 200)
            Toggle.TextSize = 12
            StyleElement(Toggle)

            local Indicator = Instance.new("Frame")
            Indicator.Size = UDim2.new(1, 0, 0, 1)
            Indicator.Position = UDim2.new(0, 0, 1, -1)
            Indicator.BorderSizePixel = 0
            Indicator.BackgroundColor3 = state and Color3.fromRGB(80, 220, 120) or Color3.fromRGB(220, 80, 80)
            Indicator.Parent = Toggle

            Toggle.MouseEnter:Connect(function() Typewrite(desc or text) end)
            Toggle.MouseLeave:Connect(ResetTitle)
            Toggle.MouseButton1Click:Connect(function()
                state = not state
                TweenService:Create(Indicator, TweenInfo.new(0.2), {BackgroundColor3 = state and Color3.fromRGB(80, 220, 120) or Color3.fromRGB(220, 80, 80)}):Play()
                callback(state)
            end)

            RunService.Heartbeat:Wait()
            Page.CanvasSize = UDim2.new(0, 0, 0, PageGrid.AbsoluteContentSize.Y)
        end

        function Elements:AddTextBox(placeholder, desc, callback)
            local Box = Instance.new("TextBox")
            Box.Parent = Page
            Box.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
            Box.Font = Enum.Font.Code
            Box.PlaceholderText = placeholder
            Box.PlaceholderColor3 = Color3.fromRGB(80, 80, 80)
            Box.Text = ""
            Box.TextColor3 = Color3.fromRGB(255, 255, 255)
            Box.TextSize = 12
            Box.ClearTextOnFocus = false
            StyleElement(Box)

            Box.MouseEnter:Connect(function() Typewrite(desc or placeholder) end)
            Box.MouseLeave:Connect(ResetTitle)
            Box.FocusLost:Connect(function()
                callback(Box.Text)
                Box.Text = ""
            end)

            RunService.Heartbeat:Wait()
            Page.CanvasSize = UDim2.new(0, 0, 0, PageGrid.AbsoluteContentSize.Y)
        end

        function Elements:AddDropdown(name, options, callback)
            local Dropdown = Instance.new("TextButton")
            Dropdown.Parent = Page
            Dropdown.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
            Dropdown.Font = Enum.Font.Code
            Dropdown.Text = name
            Dropdown.TextColor3 = Color3.fromRGB(200, 200, 200)
            Dropdown.TextSize = 12
            StyleElement(Dropdown)

            local Container = Instance.new("ScrollingFrame")
            Container.Parent = Dropdown
            Container.BackgroundColor3 = Color3.fromRGB(15, 15, 17)
            Container.BorderSizePixel = 0
            Container.Position = UDim2.new(0, 0, 1, 4)
            Container.Size = UDim2.new(1, 0, 0, 100)
            Container.Visible = false
            Container.ZIndex = 10
            Container.ScrollBarThickness = 2
            Container.ScrollBarImageColor3 = Color3.fromRGB(60, 60, 60)
            StyleElement(Container)

            local UIList = Instance.new("UIListLayout")
            UIList.Parent = Container
            UIList.SortOrder = Enum.SortOrder.LayoutOrder

            local open = false
            Dropdown.MouseEnter:Connect(function() Typewrite("Dropdown: " .. name) end)
            Dropdown.MouseLeave:Connect(ResetTitle)
            
            Dropdown.MouseButton1Click:Connect(function()
                open = not open
                Container.Visible = open
            end)

            for _, option in pairs(options) do
                local OptBtn = Instance.new("TextButton")
                OptBtn.Size = UDim2.new(1, 0, 0, 25)
                OptBtn.BackgroundTransparency = 1
                OptBtn.Font = Enum.Font.Code
                OptBtn.Text = option
                OptBtn.TextColor3 = Color3.fromRGB(130, 130, 130)
                OptBtn.TextSize = 11
                OptBtn.Parent = Container
                OptBtn.ZIndex = 11

                OptBtn.MouseButton1Click:Connect(function()
                    for _, v in pairs(Container:GetChildren()) do
                        if v:IsA("TextButton") then
                            v.TextColor3 = Color3.fromRGB(130, 130, 130)
                        end
                    end
                    OptBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                    callback(option)
                    open = false
                    Container.Visible = false
                end)
            end
            
            Container.CanvasSize = UDim2.new(0, 0, 0, UIList.AbsoluteContentSize.Y)
            RunService.Heartbeat:Wait()
            Page.CanvasSize = UDim2.new(0, 0, 0, PageGrid.AbsoluteContentSize.Y)
        end

        return Elements
    end
    return Tabs
end

return Library
